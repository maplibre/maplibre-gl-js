{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": false,
    "noEmit": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "skipLibCheck": false,
    "strict": false,
    "target": "es2022",
    "useDefineForClassFields": false,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "geojson",
      "offscreencanvas"
    ]
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "esm": true,
    "compilerOptions": {
      "target": "es2022",
      "types": [
        "node"
      ]
    },
    "logError": true,
    "pretty": true
  },
  "include": [
    "rolldown.config.*",
    "src/**/*",
    "test/bench/**/*",
    "test/integration/**/*",
    "test/unit/**/*",
    "vitest.config.*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build/rolldown",
    "test/bench/run-benchmarks.ts",
    "test/bench/gl-stats.ts",
    "test/bench/**/*generated*",
    "test/bench/**/benchmarks_worker.mjs",
    "test/integration/bundler/vite-rollup-esbuild/**",
    "test/integration/bundler/vite-rolldown/**",
    "test/integration/bundler/webpack/**",
    "test/integration/bundler/esbuild/**",
    "test/integration/bundler/rollup/**"
  ]
}
