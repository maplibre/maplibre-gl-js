{
    "version": 8,
    "glyphs": "local://glyphs/{fontstack}/{range}.pbf",
    "metadata": {
        "test": {
            "height": 256,
            "width": 256,
            "collisionDebug": true
        }
    },
    "center": [0, 0],
    "zoom": 15,
    "bearing": 0,
    "pitch": 70,
    "sources": {
        "geometry": {
            "type": "geojson",
            "data": {
                "type": "FeatureCollection",
                "features": [
                    {
                        "type": "Feature",
                        "properties": {"label": "back", "elevation": 0},
                        "geometry": {"type": "Point", "coordinates": [0, 0.0015]}
                    },
                    {
                        "type": "Feature",
                        "properties": {"label": "front", "elevation": 190},
                        "geometry": {"type": "Point", "coordinates": [0.0003, -0.0015]}
                    }
                ]
            }
        }
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {"background-color": "white"}
        },
        {
            "id": "labels",
            "type": "symbol",
            "source": "geometry",
            "layout": {
                "symbol-placement": "point",
                "symbol-elevation": ["get", "elevation"],
                "text-field": ["get", "label"],
                "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
                "text-size": 24
            },
            "paint": {
                "text-color": "#000"
            }
        }
    ]
}
