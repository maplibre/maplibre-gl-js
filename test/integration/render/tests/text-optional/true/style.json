{
  "version": 8,
  "metadata": {
    "test": {
      "width": 128,
      "height": 128
    }
  },
  "sources": {
    "geojson": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": { "name": "Test Label" },
            "geometry": { "type": "Point", "coordinates": [0, 0] }
          }
        ]
      }
    }
  },
  "glyphs": "local://glyphs/{fontstack}/{range}.pbf",
  "sprite": "local://sprites/sprite",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "white"
      }
    },
    {
      "id": "blocker",
      "type": "symbol",
      "source": "geojson",
      "layout": {
        "text-field": "Blocker Text",
        "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
        "text-overlap": "always"
      }
    },
    {
      "id": "symbol",
      "type": "symbol",
      "source": "geojson",
      "layout": {
        "icon-image": "triangle-stroked-12",
        "text-field": "{name}",
        "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
        "text-optional": true
      }
    }
  ]
}
