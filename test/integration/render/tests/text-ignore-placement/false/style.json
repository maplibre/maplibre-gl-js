{
    "version": 8,
    "metadata": {
        "test": {
            "width": 256,
            "height": 256
        }
    },
    "sources": {
        "geojson": {
            "type": "geojson",
            "data": {
                "type": "FeatureCollection",
                "features": [
                    {
                        "type": "Feature",
                        "properties": { "name": "Blocks Icons" },
                        "geometry": { "type": "Point", "coordinates": [0, 0] }
                    }
                ]
            }
        }
    },
    "glyphs": "local://glyphs/{fontstack}/{range}.pbf",
    "sprite": "local://sprites/sprite",
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "white"
            }
        },
        {
            "id": "icons",
            "type": "symbol",
            "source": "geojson",
            "layout": {
                "icon-image": "dot.sdf",
                "icon-size": 2,
                "icon-padding": 0
            },
            "paint": {
                "icon-color": "blue"
            }
        },
        {
            "id": "labels",
            "type": "symbol",
            "source": "geojson",
            "layout": {
                "text-field": "{name}",
                "text-font": ["Open Sans Semibold", "Arial Unicode MS Bold"],
                "text-size": 24,
                "text-overlap": "always",
                "text-ignore-placement": false
            }
        }
    ]
}
